@import "components.giom" as comps

@main
    +comps.page_wrapper("Posts tagged " + Model.Tag.Name)
        +comps.hero(("Posts tagged " + Model.Tag.Name), "Browse the latest published articles for this topic." ; cover="/seed-data/images/sqlite-hero.jpg")
        div.container
            div.grid
                @for post in Model.Posts
                    +comps.post_card(post)
            +comps.pager(Model.Pager)
