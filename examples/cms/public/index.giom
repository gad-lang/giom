@import "components.giom" as comps

@main
    +comps.page_wrapper("Home")
        +comps.hero("A modern GION CMS", "Publish pages, post lists, and editorial stories from a compact Go application." ; cover="/seed-data/images/about-hero.jpg")
        div.container
            div.grid
                @for post in Model.Posts
                    +comps.post_card(post)
